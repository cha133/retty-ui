{
  "name": "retty-ui",
  "version": "0.3.2",
  "description": "Imperative TUI core + React 19 bindings. Pure TypeScript, zero native dependencies.",
  "license": "MIT",
  "author": "cha133",
  "keywords": [
    "tui",
    "terminal",
    "react",
    "yoga",
    "flexbox",
    "bun",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cha133/retty-ui.git"
  },
  "bugs": {
    "url": "https://github.com/cha133/retty-ui/issues"
  },
  "homepage": "https://github.com/cha133/retty-ui#readme",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "import": "./src/react/index.ts"
    },
    "./react/jsx-runtime": {
      "types": "./src/react/jsx-runtime.ts",
      "import": "./src/react/jsx-runtime.ts"
    },
    "./react/jsx-dev-runtime": {
      "types": "./src/react/jsx-dev-runtime.ts",
      "import": "./src/react/jsx-dev-runtime.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "AGENTS.md",
    "CLAUDE.md",
    "LICENSE",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "test": "bun test",
    "test:render": "bun test tests/render.test.ts",
    "typecheck": "tsc --noEmit",
    "example:imperative": "bun run examples/agent-imperative.ts",
    "example:react": "bun run examples/agent-react.tsx",
    "lint": "biome check",
    "lint:fix": "biome check --write --unsafe",
    "format": "biome format --write",
    "check": "biome check --write --unsafe",
    "ci": "biome ci"
  },
  "dependencies": {
    "yoga-layout-tui": "^0.2.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-reconciler": "^0.33.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-reconciler": {
      "optional": false
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/bun": "latest",
    "@types/react": "^19.2.0",
    "@types/react-reconciler": "^0.33.0",
    "react": "^19.2.0",
    "react-reconciler": "^0.33.0",
    "typescript": "^5"
  }
}
